{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "outputFileTracingIncludes": {
    "api/index.js": [
      "dist/**",
      "node_modules/.prisma/**",
      "node_modules/@prisma/client/**"
    ]
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
