Thumbs.db
desktop.ini

# IDE files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Flutter specific ignores (at root level if mobile is nested)
**/mobile/.dart_tool/
**/mobile/.flutter-plugins
**/mobile/.flutter-plugins-dependencies
**/mobile/.packages
**/mobile/build/
**/mobile/android/app/key.properties
**/mobile/ios/Flutter/Flutter.podspec
**/mobile/ios/Flutter/Generated.xcconfig
**/mobile/ios/Flutter/flutter_export_environment.sh

# Web specific ignores
**/frontend/node_modules/
**/frontend/dist/
**/frontend/.env
**/frontend/.env.local
**/frontend/.env.*.local

# NestJS Backend ignores
**/backend/node_modules/
**/backend/dist/
**/backend/dev.db*
**/backend/.env
**/backend/.env.local
**/backend/.env.*.local
**/backend/npm-debug.log*
